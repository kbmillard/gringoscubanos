# Site URL for metadata + JSON-LD (set to your production domain).
NEXT_PUBLIC_SITE_URL=

# Optional public inbox for catering form "Send inquiry" (mailto). If unset, opens SMS to the site phone with the same text.
NEXT_PUBLIC_CATERING_EMAIL=

# Menu CSV (Google Sheets publish). Prefer MENU_CSV_URL for server-only fetch.
MENU_CSV_URL=
NEXT_PUBLIC_MENU_CSV_URL=

# Locations CSV — includes messageBoard column for Today's truck note.
LOCATIONS_CSV_URL=
NEXT_PUBLIC_LOCATIONS_CSV_URL=

# Upcoming schedule CSV.
SCHEDULE_CSV_URL=
NEXT_PUBLIC_SCHEDULE_CSV_URL=

# Browser/public Google Maps key (referrer-restricted). Used for embeds + client geocoding.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional server Geocoding API key (IP-restricted). Not required if client geocode is enough.
GOOGLE_MAPS_SERVER_KEY=
GOOGLE_MAPS_API_KEY=

# Clover (sandbox) — optional until live checkout.
NEXT_PUBLIC_CLOVER_PUBLIC_TOKEN_SANDBOX=
NEXT_PUBLIC_CLOVER_MERCHANT_ID_SANDBOX=
NEXT_PUBLIC_CLOVER_ENV=sandbox
